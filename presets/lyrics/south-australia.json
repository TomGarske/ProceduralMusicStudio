{
  "presetId": "south-australia",
  "title": "South Australia",
  "attribution": "Traditional capstan shanty, public domain (c. 1850s).",
  "sections": [
    {
      "phaseId": "phase1",
      "lines": [
        { "beatOffset": 0,  "text": "In South Australia I was born" },
        { "beatOffset": 8,  "text": "Heave away, haul away!" },
        { "beatOffset": 16, "text": "In South Australia round Cape Horn" },
        { "beatOffset": 24, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase2",
      "lines": [
        { "beatOffset": 0,  "text": "Haul away your rolling king" },
        { "beatOffset": 8,  "text": "Heave away, haul away!" },
        { "beatOffset": 16, "text": "Haul away, oh hear me sing" },
        { "beatOffset": 24, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase3",
      "lines": [
        { "beatOffset": 0,  "text": "As I walked out one morning fair" },
        { "beatOffset": 12, "text": "Heave away, haul away!" },
        { "beatOffset": 24, "text": "'Twas there I met Miss Nancy Blair" },
        { "beatOffset": 36, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase4",
      "lines": [
        { "beatOffset": 0,  "text": "Haul away your rolling king" },
        { "beatOffset": 12, "text": "Heave away, haul away!" },
        { "beatOffset": 24, "text": "Haul away, oh hear me sing" },
        { "beatOffset": 36, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase5",
      "lines": [
        { "beatOffset": 0,  "text": "I shook her hand and I said goodbye" },
        { "beatOffset": 8,  "text": "Heave away, haul away!" },
        { "beatOffset": 16, "text": "And she said, 'Sailor, won't you come by?'" },
        { "beatOffset": 24, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase6",
      "lines": [
        { "beatOffset": 0,  "text": "Haul away your rolling king" },
        { "beatOffset": 12, "text": "Heave away, haul away!" },
        { "beatOffset": 24, "text": "Haul away, oh hear me sing" },
        { "beatOffset": 36, "text": "We're bound for South Australia!" }
      ]
    },
    {
      "phaseId": "phase7",
      "lines": [
        { "beatOffset": 0,  "text": "Heave away, haul away!" },
        { "beatOffset": 8,  "text": "We're bound for South Australia!" },
        { "beatOffset": 16, "text": "South Australia..." }
      ]
    }
  ]
}
