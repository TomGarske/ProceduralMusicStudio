{
  "presetId": "randy-dandy-oh",
  "title": "Randy Dandy Oh",
  "attribution": "Traditional halyard shanty, public domain (c. 1800s).",
  "sections": [
    {
      "phaseId": "phase1",
      "lines": [
        { "beatOffset": 0,  "text": "Now we are ready to head for the Horn" },
        { "beatOffset": 8,  "text": "Way, hey, roll and go!" },
        { "beatOffset": 16, "text": "Our boots and our clothes, boys, are all in the pawn" }
      ]
    },
    {
      "phaseId": "phase2",
      "lines": [
        { "beatOffset": 0,  "text": "To be rollicking randy dandy-oh!" },
        { "beatOffset": 8,  "text": "Heave a pawl, oh, heave away!" },
        { "beatOffset": 16, "text": "Way, hey, roll and go!" }
      ]
    },
    {
      "phaseId": "phase3",
      "lines": [
        { "beatOffset": 0,  "text": "Anything for a quiet life we cried" },
        { "beatOffset": 8,  "text": "Way, hey, roll and go!" },
        { "beatOffset": 16, "text": "The mate knocked on the door and we lay still and died" },
        { "beatOffset": 24, "text": "To be rollicking randy dandy-oh!" }
      ]
    },
    {
      "phaseId": "phase4",
      "lines": [
        { "beatOffset": 0,  "text": "Heave a pawl, oh, heave away!" },
        { "beatOffset": 12, "text": "Way, hey, roll and go!" },
        { "beatOffset": 24, "text": "The mate he's a devil and the bosun's a hound" },
        { "beatOffset": 36, "text": "To be rollicking randy dandy-oh!" }
      ]
    },
    {
      "phaseId": "phase5",
      "lines": [
        { "beatOffset": 0,  "text": "Way, hey, roll and go!" },
        { "beatOffset": 8,  "text": "We'll haul away together!" },
        { "beatOffset": 16, "text": "To be rollicking randy dandy-oh!" }
      ]
    },
    {
      "phaseId": "phase6",
      "lines": [
        { "beatOffset": 0,  "text": "Heave a pawl, oh, heave away!" },
        { "beatOffset": 12, "text": "Way, hey, roll and go!" },
        { "beatOffset": 24, "text": "We're outward bound for Vallipo Bay!" },
        { "beatOffset": 36, "text": "To be rollicking randy dandy-oh!" }
      ]
    },
    {
      "phaseId": "phase7",
      "lines": [
        { "beatOffset": 0,  "text": "Way, hey, roll and go!" },
        { "beatOffset": 8,  "text": "Rollicking randy dandy-oh!" },
        { "beatOffset": 16, "text": "Randy dandy-oh..." }
      ]
    }
  ]
}
